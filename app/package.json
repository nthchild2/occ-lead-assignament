  },
  "dependencies": {
    "@expo-google-fonts/bricolage-grotesque": "^0.4.0",
    "@expo-google-fonts/inter": "^0.4.0",
    "@expo-google-fonts/jetbrains-mono": "^0.4.0",
    "@expo/vector-icons": "^15.1.1",
    "@gorhom/bottom-sheet": "^5.0.0",
    "@notifee/react-native": "^9.0.0",
    "@occ/shared": "workspace:*",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-firebase/analytics": "^20.0.0",
    "@react-native-firebase/app": "^20.0.0",
    "@react-native-firebase/perf": "^20.0.0",
    "@shopify/flash-list": "^2.0.2",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.0",
    "expo-font": "~14.0.12",
    "expo-image": "~3.0.11",
    "expo-router": "~6.0.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.0",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.16.0",
    "react-native-worklets": "0.5.1",
    "zod": "^3.24.0",
    "zustand": "^4.5.0"
