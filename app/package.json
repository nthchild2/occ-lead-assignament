    }
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/jest-native": "^5.4.0",
    "@testing-library/react-native": "^12.4.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.19.43",
    "@types/react": "~19.1.17",
    "@types/react-native": "^0.73.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "msw": "^2.2.0",
    "react-test-renderer": "19.1.0",
    "typescript": "^5.4.0"
